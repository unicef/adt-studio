{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ADT Studio",
  "version": "0.1.0",
  "identifier": "org.unicef.adt-studio",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --filter @adt/studio build && pnpm --filter @adt/api build:sidecar",
    "frontendDist": "../../studio/dist"
  },
  "app": {
    "windows": [
      {
        "title": "ADT Studio",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/api-server"],
    "resources": {
      "../../../prompts/**/*": "prompts/",
      "../../../templates/**/*": "templates/",
      "../../../config.yaml": ".",
      "../../../config/**/*": "config/",
      "../../../assets/styleguides/**/*": "assets/styleguides/"
    }
  }
}
