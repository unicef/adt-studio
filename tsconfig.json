{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "exclude": ["adt-studio"],
  "references": [
    { "path": "packages/types" },
    { "path": "packages/pdf" },
    { "path": "packages/llm" },
    { "path": "packages/storage" },
    { "path": "packages/pipeline" }
  ]
}
